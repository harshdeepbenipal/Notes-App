<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/noteDetailLayout">

    <!-- Guideline for top bar -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/detailBarGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.15"/>

    <!-- Guideline for bottom bar -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/editBottomGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.91"
        />

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/detailBarLayout"

        android:layout_width="0dp"
        android:layout_height="0dp"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/detailBarGuideline"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/detailLinear"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Toolbar background -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/detailToolbar"

                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:background="@color/transparent"
                android:backgroundTint="#504D6794"
                android:backgroundTintMode="add"
                />

            <!-- Guideline for back button -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/detailLeftGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"

                app:layout_constraintGuide_percent="0.2"/>

            <!-- Back Button (Returns to note navigation -->
            <ImageButton
                android:id="@+id/backButton"

                android:layout_width="0dp"
                android:layout_height="0dp"

                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:backgroundTint="@color/button"

                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="@id/detailLeftGuideline"

                android:src="@drawable/back"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Note Content Area -->

    <!-- Guideline for title -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/titleGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.24"
        />

    <!-- Note Title -->
    <TextView
        android:id="@+id/noteDetailTitle"

        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:text="Note Title"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="8dp"

        app:layout_constraintTop_toBottomOf="@id/detailBarGuideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/titleGuideline"/>

    <!-- Note Content -->
    <TextView
        android:id="@+id/noteDetailContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Full note content goes here..."
        android:textSize="16sp"
        android:textColor="@android:color/black"
        android:padding="8dp"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/noteDetailTitle"
        app:layout_constraintBottom_toTopOf="@id/editNoteButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Guideline for bottom of bar right-->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottomRightGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.8"
        />
    <!-- Edit Button (styled like save/back button if desired) -->
    <ImageButton
        android:id="@+id/editNoteButton"

        android:layout_width="0dp"
        android:layout_height="0dp"

        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:backgroundTint="@color/button"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editBottomGuideline"
        app:layout_constraintStart_toEndOf="@id/bottomRightGuideline"

        android:src="@drawable/edit"
        android:contentDescription="Edit Note"
        />

</androidx.constraintlayout.widget.ConstraintLayout>