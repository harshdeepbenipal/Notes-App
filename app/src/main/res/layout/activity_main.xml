<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Login Screen -->

    <!-- reference used -->
    <!-- https://proandroiddev.com/getting-your-constraints-right-constraintlayout-786254ed1166 -->

    <!-- Guideline for top of layout -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.02"
        />

    <!-- Guideline horizontal where enter fields begin -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/enterGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.3"
        />

    <!-- Guideline horizonal for end of enter fields -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centerGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.65"
        />

    <!-- Guideline for bottom of layout -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottomGuideline"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        app:layout_constraintGuide_begin="0dp"
        app:layout_constraintGuide_percent="0.95"
        />

    <!-- Welcome text -->
    <TextView
        android:id="@+id/loginText"

        android:layout_width="0dp"
        android:layout_height="wrap_content"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topGuideline"
        app:layout_constraintBottom_toTopOf="@id/enterGuideline"

        android:layout_marginTop="25dp"
        android:gravity="center"

        android:text="ScRibble"
        android:textSize="40sp"
        android:textAlignment="center"
        />

    <!-- Short greeting text -->

    <!-- Username enter field -->
    <TextView
        android:id="@+id/greeting"

        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:gravity="center"
        android:text="Ready to note?"
        android:textAlignment="center"
        android:textSize="14sp"

        app:layout_constraintBottom_toTopOf="@id/enterGuideline"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/loginText"

        app:layout_constraintVertical_bias="0.0" />

    <EditText
        android:id="@+id/username"
        android:layout_width="300dp"
        android:layout_height="45dp"


        android:autofillHints="username"
        android:hint="Email"
        android:inputType="textVisiblePassword"

        app:layout_constraintBottom_toTopOf="@id/password"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/enterGuideline"
        app:layout_constraintVertical_bias="0.6" />

    <!-- Password enter field -->
    <EditText
        android:id="@+id/password"

        android:layout_width="300dp"
        android:layout_height="wrap_content"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/centerGuideline"
        app:layout_constraintTop_toBottomOf="@id/enterGuideline"

        android:layout_marginBottom="2dp"

        android:autofillHints="password"
        android:hint="Password"
        android:inputType="textPassword"

        app:layout_constraintVertical_bias="0.65"

        />

    <!-- Show password toggle -->
    <CheckBox
        android:id="@+id/show"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:minWidth="0dp"
        android:minHeight="0dp"

        app:layout_constraintStart_toStartOf="@id/password"
        app:layout_constraintTop_toBottomOf="@id/password"
        app:layout_constraintBottom_toTopOf="@id/centerGuideline"

        android:checked="false"
        android:text="Show Password"

        app:layout_constraintVertical_bias="0.05"
        />

    <!--Login button -->
    <Button
        android:id="@+id/loginButton"

        android:layout_width="180dp"
        android:layout_height="wrap_content"

        app:layout_constraintTop_toBottomOf="@id/centerGuideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/register"

        app:layout_constraintVertical_bias="0.1"

        android:clickable="true"
        android:text="LOGIN"
        android:textSize="16sp"

        android:backgroundTint="@color/button"
        />

    <!-- New user text -->
    <TextView
        android:id="@+id/newUser"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomGuideline"
        app:layout_constraintEnd_toStartOf="@id/register"
        app:layout_constraintHorizontal_chainStyle="packed"

        android:gravity="center"
        android:layout_marginEnd="5dp"

        android:text="New User?"
        android:checked="true"
        android:textSize="16sp"
        />

    <!-- Register text -->
    <TextView
        android:id="@+id/register"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/newUser"
        app:layout_constraintBottom_toTopOf="@id/bottomGuideline"

        android:gravity="center"
        android:layout_marginStart="5dp"


        android:text="REGISTER HERE"
        android:checked="true"
        android:textSize="16sp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"

        android:textColor="@color/link"

        />

</androidx.constraintlayout.widget.ConstraintLayout>